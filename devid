<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Devid Pun Magar | Portfolio</title>

<style>

{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial;
}

body{
background:#0f172a;
color:white;
scroll-behavior:smooth;
}

/ HEADER /

header{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px;
background:#020617;
position:fixed;
width:100%;
z-index:1000;
}

header h2{
color:#38bdf8;
}

nav ul{
display:flex;
list-style:none;
}

nav ul li{
margin-left:20px;
}

nav ul li a{
color:white;
text-decoration:none;
font-weight:bold;
}

.menu{
display:none;
font-size:25px;
cursor:pointer;
}

/ HERO /

.hero{
height:100vh;
display:flex;
justify-content:center;
align-items:center;
flex-direction:column;
text-align:center;
background:linear-gradient(120deg,#1e293b,#020617);
}

.hero h1{
font-size:40px;
}

.typing{
color:#38bdf8;
margin-top:10px;
font-size:22px;
}

/ ABOUT /

section{
padding:80px 20px;
text-align:center;
}

.about p{
max-width:700px;
margin:auto;
line-height:1.6;
}

/ SKILLS /

.skill{
width:80%;
margin:20px auto;
text-align:left;
}

.bar{
background:#334155;
height:10px;
border-radius:10px;
}

.progress{
height:10px;
background:#38bdf8;
border-radius:10px;
width:0;
}

/ PROJECTS /

.projects{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
margin-top:30px;
}

.card{
background:#1e293b;
padding:20px;
border-radius:10px;
transition:0.3s;
}

.card:hover{
transform:translateY(-10px);
}

/ BUTTON /

.btn{
padding:10px 20px;
background:#38bdf8;
border:none;
color:black;
margin-top:20px;
cursor:pointer;
}

/ CONTACT /

input,textarea{
width:80%;
padding:10px;
margin:10px;
border:none;
border-radius:5px;
}

/ FOOTER /

footer{
background:#020617;
padding:20px;
text-align:center;
margin-top:40px;
}

/ MOBILE /

@media(max-width:768px){

nav ul{
display:none;
flex-direction:column;
background:#020617;
position:absolute;
top:60px;
right:0;
width:200px;
}

nav ul.show{
display:flex;
}

.menu{
display:block;
}

}

</style>
</head>

<body>

<header>

<h2>Devid Pun Magar</h2>

<div class="menu" onclick="menu()">☰</div>

<nav>
<ul id="nav">
<li><a href="#home">Home</a></li>
<li><a href="#about">About</a></li>
<li><a href="#skills">Skills</a></li>
<li><a href="#projects">Projects</a></li>
<li><a href="#contact">Contact</a></li>
</ul>
</nav>

</header>

<!-- HERO -->

<section class="hero" id="home">
<img src="da.jpeg" alt="Profile Image" width="150" height="150" style="border-radius:50%;">
<h1>Hello I'm Devid Pun Magar</h1>

<div class="typing" id="typing"></div>

<a href="#" class="btn">Download CV</a>

</section>

<!-- ABOUT -->

<section class="about" id="about">

<h2>About Me</h2>

<p>
My name is Devid Pun Magar. I am an IT student studying at Aadim National College.
I am passionate about programming, web development and technology.
I enjoy creating websites, coding in C programming and learning modern software development skills.
</p>

</section>

<!-- SKILLS -->

<section id="skills">

<h2>My Skills</h2>

<div class="skill">
HTML
<div class="bar"><div class="progress" data-width="90%"></div></div>
</div>

<div class="skill">
CSS
<div class="bar"><div class="progress" data-width="85%"></div></div>
</div>

<div class="skill">
JavaScript
<div class="bar"><div class="progress" data-width="70%"></div></div>
</div>

<div class="skill">
C Programming
<div class="bar"><div class="progress" data-width="80%"></div></div>
</div>

</section>

<!-- PROJECTS -->

<section id="projects">

<h2>My Projects</h2>

<div class="projects">

<div class="card">
<h3>Portfolio Website</h3>
<p>Personal portfolio showing my skills and work.</p>
</div>

<div class="card">
<h3>Sorting Algorithms</h3>
<p>Implemented Bubble Sort, Selection Sort and Merge Sort in C.</p>
</div>

<div class="card">
<h3>Excel Bill System</h3>
<p>Created professional bill generator using Excel.</p>
</div>

</div>

</section>

<!-- CONTACT -->

<section id="contact">

<h2>Contact Me</h2>

<input type="text" placeholder="Your Name"><br>
<input type="email" placeholder="Your Email"><br>

<textarea placeholder="Message"></textarea><br>

<button class="btn">Send</button>

</section>

<footer>

<p>© 2026   Devid pun magar| Aadim National College</p>

</footer>

<script>

/ MENU /

function menu(){
document.getElementById("nav").classList.toggle("show");
}

/ TYPING /

let text="IT Student | Web Developer | Programmer";
let i=0;

function typing(){

if(i<text.length){
document.getElementById("typing").innerHTML+=text.charAt(i);
i++;
setTimeout(typing,80);
}

}

typing();

/ SKILL ANIMATION */

let skills=document.querySelectorAll(".progress");

skills.forEach(skill=>{
let width=skill.getAttribute("data-width");
setTimeout(()=>{
skill.style.width=width;
},500);
});

</script>

</body>
</html>
